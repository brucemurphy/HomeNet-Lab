<?xml version="1.0" encoding="utf-8"?>
<Configuration>
  <FTP>
    <Server>ftp://your-ftp-server.com</Server>
    <Username>your-ftp-username</Username>
    <Password>your-ftp-password</Password>
    <RemotePath>/public_html/</RemotePath>
    <HtmlFileName>server01.html</HtmlFileName>
    <!-- Note: RdpFileName not needed when using RDPTargets section -->
  </FTP>

  <Security>
    <AccessPassword>YourSecurePassword123</AccessPassword>
  </Security>

  <RDPTargets>
    <!-- Host PC -->
    <Target>
      <Name>Host - SERVER-01</Name>
      <Port>3389</Port>
      <FileName>server01-host.rdp</FileName>
      <Enabled>true</Enabled>
    </Target>
    
    <!-- Virtual PC 1 - Windows Server -->
    <Target>
      <Name>VPC - WinServer2022</Name>
      <Port>3390</Port>
      <FileName>server01-vpc-winserver.rdp</FileName>
      <Enabled>true</Enabled>
    </Target>
    
    <!-- Virtual PC 2 - Development Environment -->
    <Target>
      <Name>VPC - DevEnvironment</Name>
      <Port>3391</Port>
      <FileName>server01-vpc-dev.rdp</FileName>
      <Enabled>true</Enabled>
    </Target>
    
    <!-- Virtual PC 3 - Test Environment (Disabled) -->
    <Target>
      <Name>VPC - TestEnv</Name>
      <Port>3392</Port>
      <FileName>server01-vpc-test.rdp</FileName>
      <Enabled>false</Enabled>
    </Target>
  </RDPTargets>

  <Services>
    <Service>
      <Name>Emby Media Server</Name>
      <Port>8096</Port>
      <Enabled>true</Enabled>
    </Service>
    <Service>
      <Name>Plex Media Server</Name>
      <Port>32400</Port>
      <Enabled>true</Enabled>
    </Service>
  </Services>

  <AutoPublish>
    <Enabled>true</Enabled>
    <FrequencySeconds>300</FrequencySeconds>
  </AutoPublish>
</Configuration>
