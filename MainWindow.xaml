<Window x:Name="HomeNet_Lab" x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HomeNet Lab"
        Height="768"
        Width="1280"
        WindowStyle="SingleBorderWindow"
        Background="Black"
        WindowStartupLocation="CenterScreen" 
        Icon="/HomeNetLab.png">

    <Window.Resources>
        <!-- Dark theme brushes -->
        <SolidColorBrush x:Key="MenuBackground" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="MenuForeground" Color="#FFFAFAFA"/>
        <SolidColorBrush x:Key="MenuHoverBackground" Color="#FF3E3E42"/>
        <SolidColorBrush x:Key="MenuPressedBackground" Color="#FF4E4E52"/>

        <!-- MenuItem Control Template -->
        <ControlTemplate x:Key="DarkMenuItemTemplate" TargetType="{x:Type MenuItem}">
            <Border x:Name="Border" 
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid>
                    <ContentPresenter x:Name="HeaderHost"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True"
                                    Margin="{TemplateBinding Padding}"/>
                    <Popup x:Name="Popup"
                           Placement="Bottom"
                           IsOpen="{TemplateBinding IsSubmenuOpen}"
                           AllowsTransparency="True"
                           Focusable="False"
                           PopupAnimation="Fade">
                        <Border x:Name="SubmenuBorder"
                                Background="{StaticResource MenuBackground}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="2">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </Popup>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuHoverBackground}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="{StaticResource MenuPressedBackground}"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Global MenuItem Style -->
        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Foreground" Value="{StaticResource MenuForeground}"/>
            <Setter Property="Background" Value="{StaticResource MenuBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template" Value="{StaticResource DarkMenuItemTemplate}"/>
        </Style>

        <!-- Config Editor Button Style with Rounded Corners -->
        <Style x:Key="ConfigEditorButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top" Background="{StaticResource MenuBackground}" BorderThickness="0">
            <MenuItem Header="_File" Foreground="{StaticResource MenuForeground}">
                <MenuItem Header="_Edit Config.xml" Click="EditConfigMenuItem_Click"/>
                <Separator Background="#FF3E3E42" Height="1" Margin="0"/>
                <MenuItem Header="_Publish Web Portal" Click="PublishWebPortalMenuItem_Click"/>
                <Separator Background="#FF3E3E42" Height="1" Margin="0"/>
                <MenuItem Header="_Setup Port Forwarding..." Click="SetupPortForwardingMenuItem_Click"/>
                <Separator Background="#FF3E3E42" Height="1" Margin="0"/>
                <MenuItem Header="E_xit" Click="ExitMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area (empty for template) -->
        <Grid>

            <!-- Config Editor Panel -->
            <Border x:Name="ConfigEditor"
                    Background="#BF000000"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="30,20"
                    Margin="0,0,0,100"
                    Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" MaxHeight="500">
                    <StackPanel Width="550">
                        <TextBlock Text="📝 Configuration Editor"
                                   FontSize="24"
                                   Foreground="#FFCCCCCC"
                                   Margin="0,0,0,20"
                                   HorizontalAlignment="Center"/>

                        <!-- FTP Settings -->
                        <TextBlock Text="FTP Settings" FontSize="16" Foreground="#FF00D9FF" Margin="0,0,0,10" FontWeight="Bold"/>

                        <TextBlock Text="FTP Server:" Foreground="#FFAAAAAA" Margin="0,5,0,3"/>
                        <TextBox x:Name="EditFtpServer" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <TextBlock Text="Username:" Foreground="#FFAAAAAA" Margin="0,10,0,3"/>
                        <TextBox x:Name="EditFtpUsername" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <TextBlock Text="Password:" Foreground="#FFAAAAAA" Margin="0,10,0,3"/>
                        <PasswordBox x:Name="EditFtpPassword" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <TextBlock Text="Remote Path:" Foreground="#FFAAAAAA" Margin="0,10,0,3"/>
                        <TextBox x:Name="EditRemotePath" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <TextBlock Text="HTML Filename:" Foreground="#FFAAAAAA" Margin="0,10,0,3"/>
                        <TextBox x:Name="EditHtmlFileName" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <!-- Security Settings -->
                        <TextBlock Text="Security Settings" FontSize="16" Foreground="#FF00D9FF" Margin="0,25,0,10" FontWeight="Bold"/>

                        <TextBlock Text="Access Password:" Foreground="#FFAAAAAA" Margin="0,5,0,3"/>
                        <PasswordBox x:Name="EditAccessPassword" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <!-- Auto-Publish Settings -->
                        <TextBlock Text="Auto-Publish Settings" FontSize="16" Foreground="#FF00D9FF" Margin="0,25,0,10" FontWeight="Bold"/>

                        <CheckBox x:Name="EditAutoPublishEnabled" Content="Enable Auto-Publish" Foreground="#FFAAAAAA" Margin="0,5,0,10"/>

                        <TextBlock Text="Frequency (seconds):" Foreground="#FFAAAAAA" Margin="0,5,0,3"/>
                        <TextBox x:Name="EditAutoPublishFrequency" Background="#FF2E2E2E" Foreground="White" Padding="8" BorderBrush="#FF555555" BorderThickness="1"/>

                        <!-- Services Settings -->
                        <TextBlock Text="Services" FontSize="16" Foreground="#FF00D9FF" Margin="0,25,0,10" FontWeight="Bold"/>

                        <ListBox x:Name="EditServicesList" Background="#FF2E2E2E" Foreground="White" BorderBrush="#FF555555" Height="120" Margin="0,5,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayText}" Foreground="White" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" Content="Enabled" Foreground="#FFAAAAAA" Margin="10,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="➕ Add" Click="AddServiceButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="8" FontSize="12"/>
                            <Button Grid.Column="2" Content="✏️ Edit" Click="EditServiceButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="8" FontSize="12"/>
                            <Button Grid.Column="4" Content="🗑️ Remove" Click="RemoveServiceButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="8" FontSize="12"/>
                        </Grid>

                        <!-- RDP Targets Settings -->
                        <TextBlock Text="RDP Targets (Virtual PCs)" FontSize="16" Foreground="#FF00D9FF" Margin="0,25,0,10" FontWeight="Bold"/>

                        <ListBox x:Name="EditRdpTargetsList" Background="#FF2E2E2E" Foreground="White" BorderBrush="#FF555555" Height="120" Margin="0,5,0,10">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayText}" Foreground="White" VerticalAlignment="Center"/>
                                        <CheckBox Grid.Column="1" IsChecked="{Binding Enabled}" Content="Enabled" Foreground="#FFAAAAAA" Margin="10,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="5"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="➕ Add" Click="AddRdpTargetButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="8" FontSize="12"/>
                            <Button Grid.Column="2" Content="✏️ Edit" Click="EditRdpTargetButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="8" FontSize="12"/>
                            <Button Grid.Column="4" Content="🗑️ Remove" Click="RemoveRdpTargetButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="8" FontSize="12"/>
                        </Grid>

                        <!-- File Name Info -->
                        <Border Background="#1A4A90E2" CornerRadius="5" Padding="12" Margin="0,25,0,0">
                            <StackPanel>
                                <TextBlock x:Name="EditConfigFileInfo" Foreground="#FFCCCCCC" TextWrapping="Wrap"/>
                                <CheckBox x:Name="EditSaveAsPCName" Content="Save as PC-specific config" Foreground="#FFAAAAAA" Margin="0,10,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- Buttons -->
                        <Grid Margin="0,25,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="💾 Save" Click="SaveConfigButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="12" FontSize="12"/>
                            <Button Grid.Column="2" Content="❌ Cancel" Click="CancelConfigButton_Click" 
                                    Style="{StaticResource ConfigEditorButton}"
                                    Background="#CC555555" Padding="12" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Config Display Panel in Center -->
            <Border x:Name="ConfigDisplay"
                    Background="#BF000000"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="20,15">
                <StackPanel Width="400">
                    <TextBlock Text="⚙️ Configuration"
                               FontSize="20"
                               Foreground="#FFCCCCCC"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center"/>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Config File:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigFileName" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="FTP Server:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigFtpServer" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Username:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigFtpUsername" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Remote:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigRemotePath" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Services:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigServiceName" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Ports:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigServicePort" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RDP Targets:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigRdpTargets" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="RDP Ports:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigRdpPorts" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>

                    <Border Background="#1A000000" CornerRadius="5" Padding="12" Margin="0,3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Auto-Publish:" Foreground="#FFAAAAAA" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" x:Name="ConfigAutoPublish" Foreground="#FFFFFF" FontFamily="Consolas" HorizontalAlignment="Right"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Footer with Bing wallpaper info and activity indicator -->
            <Border Background="#BF000000"
                    Margin="0,0,0,0"
                    CornerRadius="10,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom">
                <Canvas x:Name="FooterGrid"
                        Width="902"
                        Height="86">
                    <TextBlock x:Name="HeadingTextBlock"
                               Foreground="#FFCCCCCC"
                               FontSize="22"
                               Canvas.Left="31"
                               Canvas.Top="14"/>
                    <TextBlock x:Name="CopyrightTextBlock"
                               Foreground="#CCC"
                               TextWrapping="Wrap"
                               Canvas.Left="31"
                               Canvas.Top="48"/>
                    <Ellipse x:Name="Activity"
                             Width="18" Height="18"
                             Fill="#333"
                             Stroke="#555"
                             StrokeThickness="1"
                             Cursor="Hand"
                             Canvas.Right="20"
                             Canvas.Top="34"
                             ToolTip="Internet Connection Status"/>

                    <!-- RIGHT-ALIGNED PROGRESS PANEL -->
                    <StackPanel x:Name="ProgressPanel"
                                Orientation="Vertical"
                                Canvas.Right="50"
                                Canvas.Top="16"
                                Width="230">
                        <TextBlock x:Name="MountSizeProgressText"
                                   FontSize="22"
                                   Foreground="#FFE2E2E2"
                                   TextAlignment="Right"
                                   TextTrimming="None"
                                   TextWrapping="NoWrap"/>
                        <TextBlock x:Name="MountSizeProgressTextDetail"
                                   Margin="0,4,0,0"
                                   Foreground="#FFE2E2E2"
                                   TextAlignment="Right"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap"
                                   Width="230"/>
                    </StackPanel>
                </Canvas>
            </Border>
        </Grid>
    </DockPanel>
</Window>
