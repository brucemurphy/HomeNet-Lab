<?xml version="1.0" encoding="utf-8"?>
<!--
  ╔═══════════════════════════════════════════════════════════════════════╗
  ║  TEMPLATE - PC-SPECIFIC CONFIGURATION                                 ║
  ║                                                                        ║
  ║  This is an EXAMPLE configuration for multi-PC deployments.           ║
  ║  DO NOT EDIT THIS FILE - it's just a reference template!              ║
  ║                                                                        ║
  ║  TO USE:                                                               ║
  ║  1. Use File → Edit Config.xml in the app                             ║
  ║  2. Check "Save as PC-specific config" when saving                    ║
  ║  3. App will create [YOURPCNAME].xml automatically                    ║
  ║                                                                        ║
  ║  OR manually copy this file to [YOURPCNAME].xml and edit it.          ║
  ║                                                                        ║
  ║  Example: If your PC is named "SERVER-01", rename to SERVER-01.xml    ║
  ║  The app will auto-detect and load it instead of config.xml           ║
  ╚═══════════════════════════════════════════════════════════════════════╝
-->
<Configuration>
  <FTP>
    <Server>ftp://your-ftp-server.com</Server>
    <Username>your-ftp-username</Username>
    <Password>your-ftp-password</Password>
    <RemotePath>/public_html/</RemotePath>
    <HtmlFileName>server01.html</HtmlFileName>
    <!-- Legacy: Single RDP file (only used if RDPTargets section not present) -->
    <RdpFileName>server01.rdp</RdpFileName>
  </FTP>

  <Security>
    <AccessPassword>YourSecurePassword123</AccessPassword>
  </Security>

  <RDPTargets>
    <!-- Host PC -->
    <Target>
      <Name>Host - SERVER-01</Name>
      <Port>3389</Port>
      <FileName>server01-host.rdp</FileName>
      <Enabled>true</Enabled>
    </Target>
    
    <!-- Virtual PC 1 - Windows Server -->
    <Target>
      <Name>VPC - WinServer2022</Name>
      <Port>3390</Port>
      <FileName>server01-vpc-winserver.rdp</FileName>
      <Enabled>true</Enabled>
    </Target>
    
    <!-- Virtual PC 2 - Development Environment -->
    <Target>
      <Name>VPC - DevEnvironment</Name>
      <Port>3391</Port>
      <FileName>server01-vpc-dev.rdp</FileName>
      <Enabled>true</Enabled>
    </Target>
    
    <!-- Virtual PC 3 - Test Environment (Disabled) -->
    <Target>
      <Name>VPC - TestEnv</Name>
      <Port>3392</Port>
      <FileName>server01-vpc-test.rdp</FileName>
      <Enabled>false</Enabled>
    </Target>
  </RDPTargets>

  <Services>
    <Service>
      <Name>Emby Media Server</Name>
      <Port>8096</Port>
      <Enabled>true</Enabled>
    </Service>
    <Service>
      <Name>Plex Media Server</Name>
      <Port>32400</Port>
      <Enabled>true</Enabled>
    </Service>
  </Services>

  <AutoPublish>
    <Enabled>true</Enabled>
    <FrequencySeconds>300</FrequencySeconds>
  </AutoPublish>
</Configuration>
